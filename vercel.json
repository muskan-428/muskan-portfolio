{
  "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @workspace/portfolio run build",
  "outputDirectory": "artifacts/portfolio/dist/public",
  "framework": "vite",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "env": {
    "BASE_PATH": "/",
    "PORT": "3000"
  }
}
